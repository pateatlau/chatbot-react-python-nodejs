# Default environment for docker-compose
# Copy and customize as needed for local development
#
# CORS uses http://localhost because the compose frontend is served on port 80.
# For local Vite dev (port 5173), use backend-python/.env.example instead.

# LLM Provider selection: openai | gemini | groq | anthropic
LLM_PROVIDER=openai

# OpenAI configuration
OPENAI_API_KEY=sk-placeholder
OPENAI_MODEL=gpt-4o-mini

# Gemini configuration
GEMINI_API_KEY=gm-placeholder
GEMINI_MODEL=gemini-3.1-flash-lite

# Groq configuration
GROQ_API_KEY=gsk-placeholder
GROQ_MODEL=openai/gpt-oss-20b

# Anthropic configuration
ANTHROPIC_API_KEY=anthropic-placeholder
ANTHROPIC_MODEL=claude-haiku-4-5-20251001

# CORS configuration (compose frontend origin)
CORS_ALLOWED_ORIGINS=http://localhost

# Application environment
APP_ENV=development
LOG_LEVEL=INFO

# Request limits
MAX_MESSAGE_LENGTH=4000
REQUEST_TIMEOUT_SECONDS=30
REQUEST_BODY_LIMIT_BYTES=16384
RATE_LIMIT_ANONYMOUS_PER_MINUTE=30
RATE_LIMIT_AUTHENTICATED_PER_MINUTE=120

# PostgreSQL (compose postgres service)
DATABASE_URL=postgresql+asyncpg://chatbot:chatbot@postgres:5432/chatbot

# Auth (optional in development; required in production)
GOOGLE_CLIENT_ID=
JWT_SECRET=dev-insecure-jwt-secret-change-me
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRES_MINUTES=60

# Guest quota and persistence
GUEST_DAILY_MESSAGE_QUOTA=20
CHAT_PERSISTENCE_ENABLED=true
