# Optional in local dev — unset uses the Vite /api proxy to http://127.0.0.1:8000
# (same-origin). Prefer leaving this unset locally; do not point at
# http://localhost:8000 when a Docker compose backend may also own *:8000.
# Required for production/staging builds (see frontend/Dockerfile).
# VITE_API_BASE_URL=

# Google OAuth 2.0 Web client ID (public, not a secret) used by Google Identity
# Services in the browser to obtain a Google ID token for POST /api/auth/google.
# Must match backend-python GOOGLE_CLIENT_ID. Authorized JavaScript origins in
# Google Cloud Console must include http://localhost:5173 (and 127.0.0.1:5173).
VITE_GOOGLE_CLIENT_ID=
